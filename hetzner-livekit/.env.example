# Copy this file to .env on the Hetzner server and fill in real values.
# .env is gitignored at the repo root — never commit real secrets.

# Domain (A/AAAA record) pointing at this Hetzner server's IP.
# Caddy uses this to obtain a TLS cert automatically (Let's Encrypt).
LIVEKIT_DOMAIN=connect.smiring-ryugaku.com

# Separate domain (also A/AAAA -> this server) used only so Caddy can issue
# a TLS cert for LiveKit's built-in TURN/TLS relay. No real HTTP traffic is
# served on it. Must match the `turn.domain` value in livekit.yaml.
TURN_DOMAIN=turn.smiring-ryugaku.com

# Generate with: docker run --rm livekit/livekit-server generate-keys
# Set the same values as LIVEKIT_API_KEY / LIVEKIT_API_SECRET on the Cloud Run backend.
# On Cloud Run, LIVEKIT_URL should be wss://<LIVEKIT_DOMAIN>
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
